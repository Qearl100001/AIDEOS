# MiniMax LLM（Anthropic 兼容网关）
# 密钥：MiniMax 开放平台 → 账户 / API Keys
MINIMAX_API_KEY=
# 可选，默认 https://api.minimax.io/anthropic
# MINIMAX_ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic

# LLM 模型（兼容层支持 MiniMax-M2.7、MiniMax-M2.5、MiniMax-M2.1、MiniMax-M2 等）
LLM_MODEL=MiniMax-M2.5

# 通知配置（选一个即可）
FEISHU_WEBHOOK=
WECHAT_WEBHOOK=
BARK_TOKEN=

# Autocli 配置
AUTOCLI_URL=https://your-autocli-url

# OpenClaw 配置
OPENCLAW_API_URL=https://your-openclaw-server.com
OPENCLAW_API_KEY=your-api-key
OPENCLAW_CHANNEL=daily-briefing
